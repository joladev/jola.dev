<.heading level={1} class="sr-only">Johanna Larsson</.heading>

<%!-- <.hero
  title="Johanna Larsson"
  subtitle="Director of Engineering"
  description="Building teams and software that makes a difference"
  badge={random_status()}
  primary_action={%{label: "About Me", href: "/about"}}
  secondary_action={%{label: "Read My Blog", href: "/posts"}}
/> --%>

<section class="py-16 bg-surface/30">
  <div class="max-w-content mx-auto px-6 md:px-8">
    <header class="mb-12 text-center">
      <.heading level={2}>Recent Posts</.heading>
      <.text variant={:lead} class="mt-4">
        Thoughts on software engineering and technology
      </.text>
    </header>

    <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      <.blog_card :for={post <- @recent_posts} post={post} />
    </div>

    <div class="text-center mt-8">
      <.link href="/posts">
        <.button variant={:secondary}>
          View All Posts <.icon name="hero-arrow-right" class="w-4 h-4 ml-2" />
        </.button>
      </.link>
    </div>
  </div>
</section>

<section class="py-16 bg-background">
  <div class="max-w-content mx-auto px-6 md:px-8">
    <header class="mb-12 text-center">
      <.heading level={2}>Highlighted Projects</.heading>
      <.text variant={:lead} class="mt-4">
        Featured open source contributions and tools
      </.text>
    </header>

    <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      <.project_card
        title="Larm"
        description="Uptime monitoring with full request traces, multi-location verification, and status pages. Hosted in Europe.."
        tags={["Elixir", "Uptime monitoring", "EU"]}
        link="https://larm.dev/"
        external
      />

      <.project_card
        title="HRW"
        description="A library for rendezvous hashing, also known as highest random weight, in Elixir."
        tags={["Elixir", "Open Source"]}
        github_link="https://github.com/joladev/hrw"
        external
      />

      <.project_card
        title="bunnyx"
        description="A client library for the bunny.net API, in Elixir."
        tags={["Elixir", "Open Source"]}
        github_link="https://github.com/joladev/bunnyx"
        external
      />
    </div>

    <div class="text-center mt-8">
      <.link href="/projects">
        <.button variant={:secondary}>
          View All Projects <.icon name="hero-arrow-right" class="w-4 h-4 ml-2" />
        </.button>
      </.link>
    </div>
  </div>
</section>
