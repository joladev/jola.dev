<!DOCTYPE html>
<html lang="en" class="[scrollbar-gutter:stable] antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <.live_title>
      {@conn.assigns[:page_title] || "jola.dev"}
    </.live_title>
    <meta
      name="description"
      content={
        @conn.assigns[:meta_description] ||
          "Johanna Larsson is a software engineer, engineering leader, writer, and speaker with over 14 years of experience."
      }
    />
    <meta property="og:title" content={@conn.assigns[:page_title] || "jola.dev"} />
    <meta property="og:url" content={Phoenix.Controller.current_url(@conn)} />
    <meta
      property="og:description"
      content={
        @conn.assigns[:meta_description] ||
          "Johanna Larsson is a software engineer, engineering leader, writer, and speaker with over 14 years of experience."
      }
    />
    <meta property="og:type" content={if(@conn.assigns[:post], do: "article", else: "website")} />
    <meta property="og:image" content={url(~p"/images/og-image.png")} />
    <meta property="og:site_name" content="jola.dev" />
    <meta property="og:locale" content="en_US" />
    <%= if post = @conn.assigns[:post] do %>
      <meta property="article:published_time" content={Date.to_iso8601(post.date)} />
      <meta property="article:author" content="https://jola.dev/about" />
      <%= for tag <- post.tags do %>
        <meta property="article:tag" content={tag} />
      <% end %>
    <% end %>
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={@conn.assigns[:page_title] || "jola.dev"} />
    <meta
      name="twitter:description"
      content={
        @conn.assigns[:meta_description] ||
          "Johanna Larsson is a software engineer, engineering leader, writer, and speaker with over 14 years of experience."
      }
    />
    <meta name="twitter:image" content={url(~p"/images/og-image.png")} />
    <link rel="canonical" href={JolaDevWeb.Helpers.CanonicalUrl.canonical_url(@conn)} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="jola.dev RSS Feed"
      href={~p"/rss.xml"}
    />
    <link rel="preload" href={~p"/fonts/inter-latin.woff2"} as="font" type="font/woff2" crossorigin />
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}>
    </script>
    <script
      defer
      src="https://umami.devstats.io/script.js"
      data-website-id="ee45eb1e-80d4-41dd-9ee1-8cb7739a9086"
    >
    </script>
    <link rel="icon" type="image/png" href="/images/logo.png" />
    <%= for schema <- JolaDevWeb.SEO.json_ld(@conn) do %>
      <script type="application/ld+json">
        <%= raw(Jason.encode!(schema)) %>
      </script>
    <% end %>
  </head>
  <body class="min-h-screen antialiased flex flex-col">
    {@inner_content}
  </body>
</html>
