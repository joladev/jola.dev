<!DOCTYPE html>
<html lang="en" class="[scrollbar-gutter:stable] antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta :if={@conn.assigns[:noindex]} name="robots" content="noindex,follow" />

    <.live_title>
      {@conn.assigns[:page_title] || "jola.dev"}
    </.live_title>
    <meta
      name="description"
      content={
        @conn.assigns[:meta_description] ||
          "Johanna Larsson is a software engineer, engineering leader, writer, and speaker with over 14 years of experience."
      }
    />
    <meta property="og:title" content={@conn.assigns[:page_title] || "jola.dev"} />
    <meta property="og:url" content={Phoenix.Controller.current_url(@conn)} />
    <meta
      property="og:description"
      content={
        @conn.assigns[:meta_description] ||
          "Johanna Larsson is a software engineer, engineering leader, writer, and speaker with over 14 years of experience."
      }
    />
    <meta property="og:type" content={if(@conn.assigns[:post], do: "article", else: "website")} />
    <meta
      property="og:image"
      content={
        Phoenix.VerifiedRoutes.unverified_url(
          JolaDevWeb.Endpoint,
          @conn.assigns[:og_image] || "/images/og-image.png"
        )
      }
    />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={@conn.assigns[:page_title] || "jola.dev"} />
    <meta property="og:site_name" content="jola.dev" />
    <meta property="og:locale" content="en_US" />
    <%= if post = @conn.assigns[:post] do %>
      <meta
        property="article:published_time"
        content={DateTime.new!(post.date, ~T[00:00:00], "Etc/UTC") |> DateTime.to_iso8601()}
      />
      <meta property="article:author" content="https://jola.dev/about" />
      <%= for tag <- post.tags do %>
        <meta property="article:tag" content={tag} />
      <% end %>
    <% end %>
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@joladev" />
    <meta name="twitter:creator" content="@joladev" />
    <meta name="twitter:title" content={@conn.assigns[:page_title] || "jola.dev"} />
    <meta
      name="twitter:description"
      content={
        @conn.assigns[:meta_description] ||
          "Johanna Larsson is a software engineer, engineering leader, writer, and speaker with over 14 years of experience."
      }
    />
    <meta
      name="twitter:image"
      content={
        Phoenix.VerifiedRoutes.unverified_url(
          JolaDevWeb.Endpoint,
          @conn.assigns[:og_image] || "/images/og-image.png"
        )
      }
    />
    <meta name="twitter:image:alt" content={@conn.assigns[:page_title] || "jola.dev"} />
    <%= unless @conn.status && @conn.status >= 400 do %>
      <link rel="canonical" href={JolaDevWeb.Helpers.CanonicalUrl.canonical_url(@conn)} />
    <% end %>
    <link
      rel="alternate"
      type="application/rss+xml"
      title="jola.dev RSS Feed"
      href={~p"/rss.xml"}
    />
    <link
      rel="preload"
      href={~p"/fonts/inter-latin.woff2"}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="stylesheet" href={~p"/assets/app.css"} />
    <script defer type="text/javascript" src={~p"/assets/app.js"}>
    </script>
    <script
      defer
      src="https://umami.devstats.io/script.js"
      data-website-id="ee45eb1e-80d4-41dd-9ee1-8cb7739a9086"
    >
    </script>
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <%= for schema <- JolaDevWeb.SEO.json_ld(@conn) do %>
      <script type="application/ld+json">
        <%= raw(Jason.encode!(schema)) %>
      </script>
    <% end %>
  </head>
  <body class="min-h-screen antialiased flex flex-col">
    {@inner_content}
  </body>
</html>
